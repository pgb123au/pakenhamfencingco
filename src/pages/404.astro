---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Page Not Found | Pakenham Fencing"
  description="That page couldn't be found. Explore Pakenham Fencing's Colorbond, timber, pool, rural fencing & gates across Pakenham & Cardinia. (03) 9003 0108."
  canonical="https://pakenhamfencingco.com.au/404/">
  <Fragment slot="head"><meta name="robots" content="noindex, follow"></Fragment>
  <section class="hero hero-suburb">
    <div class="hero-inner">
      <span class="hero-eyebrow">404</span>
      <h1>We couldn&rsquo;t find that page.</h1>
      <p class="hero-sub">
        The page you were after has moved or never existed &mdash; but we&rsquo;re
        still here to fence your boundary, pool or gate across Pakenham and the
        Cardinia growth corridor.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="btn btn-ghost" href="/quote/">Get a free quote</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <h2>Try one of these instead.</h2>
      <div style="max-width: 60rem;">
        <p>
          Browse our fencing services &mdash;
          <a href="/services/colorbond-fencing/">Colorbond fencing</a>,
          <a href="/services/timber-paling-fencing/">timber paling fencing</a>,
          <a href="/services/pool-safety-fencing/">pool safety fencing</a>,
          <a href="/services/rural-acreage-fencing/">rural &amp; acreage fencing</a>
          and <a href="/services/gates-automation/">gates &amp; automation</a> &mdash;
          or jump to fencing in <a href="/cardinia-lakes/">Cardinia Lakes</a>,
          <a href="/officer/">Officer</a> or across
          <a href="/cardinia-shire/">Cardinia Shire</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
